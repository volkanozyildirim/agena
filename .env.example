APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8010

# Host root path that contains mapped local repositories.
# macOS default: /Users, Linux examples: /home or /home/<user>
HOST_REPO_ROOT=/Users

OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_SMALL_MODEL=gpt-4o-mini
LLM_LARGE_MODEL=gpt-4.1
MAX_CONTEXT_CHARS=8000

JWT_SECRET_KEY=replace_with_secure_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=1440

# Optional global fallback only. Preferred: configure per organization via /integrations/jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Optional global fallback only. Preferred: configure per organization via /integrations/azure
AZURE_ORG_URL=
AZURE_PROJECT=
AZURE_PAT=

GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_github_repo
GITHUB_DEFAULT_BASE_BRANCH=main

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_WEBHOOK_SECRET=

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_DATABASE=ai_agent_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_QUEUE_NAME=agent_tasks
MAX_WORKERS=8
QUEUE_LOCK_MAX_RETRIES=20
TASK_RUNNING_TIMEOUT_MINUTES=180

QDRANT_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=task_memory

MAX_AGENT_RETRIES=3

# Optional SMTP for task result emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tiqr.local
SMTP_FROM_NAME=Tiqr AI
SMTP_USE_TLS=true
SMTP_USE_SSL=false
